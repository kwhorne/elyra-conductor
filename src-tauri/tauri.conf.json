{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Elyra Conductor",
  "mainBinaryName": "elyra-conductor",
  "version": "0.4.0",
  "identifier": "com.elyra.conductor",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Elyra Conductor",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/kwhorne/elyra-conductor/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdBNkE0N0M0REY2RDUyNTQKUldSVVVtM2Z4RWRxZXEvVml6WElTQUF1bmZiQkE4TXhjQ0xycS8wcUR4b1JudWkrQlJtQjQ3NFQK"
    }
  }
}
